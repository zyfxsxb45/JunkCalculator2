// ═══════════════════════════════════════════════════════════════
// discrete.jc2 — Discrete Mathematics Standard Library v2.2.2
// Pure JC2 Implementation with Strict Type Contracts
// ═══════════════════════════════════════════════════════════════

// ┌────────────────────────────────────────────────────────┐
// │ 1. COMBINATORICS                                       │
// └────────────────────────────────────────────────────────┘

permutations(arr: any) -> list = {
    n = arr.len()
    if (n <= 1) return list(arr)
    res = list()
    for (i in range(n)) {
        curr = arr[i]
        rest = list()
        for (j in range(n)) { if (i != j) rest.push(arr[j]) }
        for (p in permutations(rest)) {
            new_p = list(curr)
            for (x in p) new_p.push(x)
            res.push(new_p)
        }
    }
    return res
}

combinations(arr: any, k: int) -> list = {
    if (k == 0) return list(list())
    if (arr.len() < k) return list()
    if (arr.len() == k) return list(arr.toList())
    
    res = list()
    first = arr[0]
    rest = arr[1:]
    
    for (c in combinations(rest, k - 1)) {
        new_c = list(first)
        for (x in c) new_c.push(x)
        res.push(new_c)
    }
    for (c in combinations(rest, k)) { res.push(c) }
    return res
}

// ┌────────────────────────────────────────────────────────┐
// │ 2. PROPOSITIONAL LOGIC (class Prop)                    │
// └────────────────────────────────────────────────────────┘

class Prop {
    init(tp: string, a: any, b: any) = {
        self.tp = tp
        self.a = a    
        self.b = b    
    }

    __bitand__(other: Prop) -> Prop = return Prop("and", self, other)
    __bitor__(other: Prop) -> Prop  = return Prop("or",  self, other)
    __neg__() -> Prop               = return Prop("not", self, "null")

    implies(other: Prop) -> Prop    = return Prop("imp", self, other)
    iff(other: Prop) -> Prop        = return Prop("iff", self, other)

    eval(env: dict) -> int = {
        tp = self.tp
        if (tp == "var") return env[self.a] ? 1 : 0
        if (tp == "not") return self.a.eval(env) ? 0 : 1
        
        ea = self.a.eval(env)
        eb = self.b.eval(env)
        if (tp == "and") return (ea && eb) ? 1 : 0
        if (tp == "or")  return (ea || eb) ? 1 : 0
        if (tp == "imp") return (!ea || eb) ? 1 : 0
        if (tp == "iff") return ea == eb ? 1 : 0
        return 0
    }

    vars() -> set = {
        tp = self.tp
        if (tp == "var") return set(self.a)
        if (tp == "not") return self.a.vars()
        return self.a.vars() | self.b.vars()
    }

    isTautology() -> bool = {
        varList = self.vars().toList().sort(); n = varList.len()
        for (i in range(2^n)) {
            env = dict()
            for (j in range(n)) { env[varList[j]] = int(i / (2^(n-1-j))) % 2 }
            if (!self.eval(env)) return false
        }
        return true
    }

    isContradiction() -> bool = {
        varList = self.vars().toList().sort(); n = varList.len()
        for (i in range(2^n)) {
            env = dict()
            for (j in range(n)) { env[varList[j]] = int(i / (2^(n-1-j))) % 2 }
            if (self.eval(env)) return false
        }
        return true
    }

    isSatisfiable() -> bool       = return !self.isContradiction()
    equiv(other: Prop) -> bool    = return self.iff(other).isTautology()

    __call__(env: dict) -> int    = return self.eval(env)

    table() -> list = {
        varList = self.vars().toList().sort(); n = varList.len()
        total = 2 ^ n
        results = list()
        for (i in range(total)) {
            env = dict()
            for (j in range(n)) { env[varList[j]] = int(i / (2^(n-1-j))) % 2 }
            res = self.eval(env)
            results.push({env: env, result: res})
        }
        return results
    }

    printTable() = {
        varList = self.vars().toList().sort(); n = varList.len()
        formula = self.str()
        sep = "-" * (n * 4 + formula.len() + 5)
        header = ""
        for (v in varList) { header += " " + str(v) + "  " }
        header += " | " + formula
        print(sep); print(header); print(sep)
        
        data = self.table()
        for (row in data) {
            env = row.env; rowStr = ""
            for (v in varList) { rowStr += " " + str(env[v]) + "  " }
            rowStr += " | " + str(row.result)
            print(rowStr)
        }
        print(sep)
    }

    __str__() -> string = {
        tp = self.tp
        if (tp == "var") return str(self.a)
        if (tp == "not") {
            sA = str(self.a)
            if (self.a.tp == "var") return "~" + sA
            return "~(" + sA + ")"
        }
        opStr = " ? "
        if (tp == "and") opStr = " & "
        if (tp == "or")  opStr = " | "
        if (tp == "imp") opStr = " => "
        if (tp == "iff") opStr = " <=> "
        return "(" + str(self.a) + opStr + str(self.b) + ")"
    }

    __eq__(other: any) -> bool = {
        if (!other.isinstance(Prop)) return false
        if (self.tp != other.tp) return false
        if (self.tp == "var" || self.tp == "not") return self.a == other.a
        return (self.a == other.a) && (self.b == other.b)
    }
}

Var(name: string) -> Prop = return Prop("var", name, "null")

// ┌────────────────────────────────────────────────────────┐
// │ 3. BINARY RELATIONS (class Relation)                   │
// └────────────────────────────────────────────────────────┘

class Relation {
    init(S: set, pairs: any = none) = {
        self.S = S
        self.R = set()
        self._pt = "List"

        if (pairs != none) {
            src = pairs.type() == "Set" ? pairs.toList() : pairs
            if (src.len() > 0) self._pt = src[0].type()
            for (p in src) self.addPair(p[0], p[1])
        }
    }

    _mp(a: any, b: any) -> any = return self._pt == "List" ? list(a, b) : [a, b]

    // ── Public Facing API (Safe CRUD) ──

    addPair(a: any, b: any) = { 
        if (!(a in self.S) || !(b in self.S)) {
            throw f"Relation Error: Both elements '{a}' and '{b}' must exist in the base set S."
        }
        self.R.add(self._mp(a, b))
        return self 
    }

    removePair(a: any, b: any) = {
        self.R.discard(self._mp(a, b))
        return self
    }

    clearPairs() = {
        self.R.clear()
        return self
    }
    
    hasPair(a: any, b: any) -> bool = return self._mp(a, b) in self.R
    __call__(a: any, b: any) -> bool = return self.hasPair(a, b)

    // ── Property Tests ──
    isReflexive() -> bool = {
        for (x in self.S) { if (!self.hasPair(x, x)) return false }
        return true
    }
    isIrreflexive() -> bool = {
        for (x in self.S) { if (self.hasPair(x, x)) return false }
        return true
    }
    isSymmetric() -> bool = {
        for (p in self.R) { [a, b] = p; if (!self.hasPair(b, a)) return false }
        return true
    }
    isAntiSymmetric() -> bool = {
        for (p in self.R) { [a, b] = p; if (a != b && self.hasPair(b, a)) return false }
        return true
    }
    isTransitive() -> bool = {
        for (p1 in self.R) {
            for (p2 in self.R) {
                [a, b] = p1; [c, d] = p2
                if (b == c && !self.hasPair(a, d)) return false
            }
        }
        return true
    }

    // ── Compound Tests ──
    isEquivalence() -> bool  = return self.isReflexive() && self.isSymmetric() && self.isTransitive()
    isPartialOrder() -> bool = return self.isReflexive() && self.isAntiSymmetric() && self.isTransitive()
    
    isTotalOrder() -> bool = {
        if (!self.isPartialOrder()) return false
        for (a in self.S) {
            for (b in self.S) {
                if (!self.hasPair(a, b) && !self.hasPair(b, a)) return false
            }
        }
        return true
    }

    // ── Algebraic Operations ──
    inverse() -> Relation = {
        r = Relation(self.S); r._pt = self._pt
        for (p in self.R) { [a, b] = p; r.R.add(r._mp(b, a)) }
        return r
    }

    compose(other: Relation) -> Relation = {
        r = Relation(self.S); r._pt = self._pt
        for (p1 in self.R) {
            for (p2 in other.R) {
                [a, b] = p1; [c, d] = p2
                if (b == c) r.R.add(r._mp(a, d))
            }
        }
        return r
    }

    // ── Closure Operations ──
    reflexiveClosure() -> Relation = {
        r = Relation(self.S); r._pt = self._pt
        for (p in self.R) r.R.add(p)
        for (x in self.S) r.R.add(r._mp(x, x))
        return r
    }

    symmetricClosure() -> Relation = {
        r = Relation(self.S); r._pt = self._pt
        for (p in self.R) { [a, b] = p; r.R.add(p); r.R.add(r._mp(b, a)) }
        return r
    }

    transitiveClosure() -> Relation = {
        current = set()
        for (p in self.R) current.add(p)
        
        changed = true
        while (changed) {
            changed = false
            toAdd = set()
            for (p1 in current) {
                for (p2 in current) {
                    [a, b] = p1; [c, d] = p2
                    if (b == c) {
                        np = self._mp(a, d)
                        if (!(np in current) && !(np in toAdd)) toAdd.add(np)
                    }
                }
            }
            if (toAdd.len() > 0) {
                for (p in toAdd) current.add(p)
                changed = true
            }
        }
        r = Relation(self.S); r._pt = self._pt; r.R = current
        return r
    }

    // ── Equivalence Classes ──
    equivalenceClasses() -> list = {
        if (!self.isEquivalence()) throw "Relation Error: equivalenceClasses subject must be an equivalence relation."
        assigned = set()
        classes = list()
        for (x in self.S) {
            if (x in assigned) continue
            cls = set()
            for (y in self.S) {
                if (self.hasPair(x, y)) { cls.add(y); assigned.add(y) }
            }
            classes.push(cls)
        }
        return classes
    }

    // ── Dunder Methods ──
    __contains__(pair: any) -> bool = return pair in self.R
    __len__() -> int                = return self.R.len()
    __str__() -> string             = return f"Relation(|S|={self.S.len()}, |R|={self.R.len()})"
}

// ┌────────────────────────────────────────────────────────┐
// │ 4. GRAPH THEORY (class Graph)                          │
// └────────────────────────────────────────────────────────┘

class Graph {
    init(directed: bool = true) = {
        self.adj = dict()
        self.directed = directed
        self._ec = 0
    }

    // ── Construction & Erasure (CRUD API) ──
    addVertex(v: any) = {
        if (!self.adj.hasKey(v)) self.adj[v] = list()
        return self
    }

    removeVertex(v: any) = {
        if (!self.adj.hasKey(v)) return self
        self.adj.discard(v) 
        
        // Cleanup orphans
        for (u in self.adj.keys()) {
            new_edges = list()
            for (e in self.adj[u]) {
                if (e[0] != v) new_edges.push(e)
            }
            self.adj[u] = new_edges
        }
        
        c = 0
        for (u in self.adj.keys()) c += self.adj[u].len()
        self._ec = self.directed ? c : c / 2
        
        return self
    }

    addEdge(u: any, v: any, w: any = 1) = {
        self.addVertex(u); self.addVertex(v)
        
        self.adj[u].push(list(v, w))
        if (!self.directed) self.adj[v].push(list(u, w))
        self._ec += 1
        return self
    }

    removeEdge(u: any, v: any) = {
        removed = false
        if (self.adj.hasKey(u)) {
            new_u = list()
            for (e in self.adj[u]) {
                if (e[0] != v) new_u.push(e)
                else removed = true
            }
            self.adj[u] = new_u
        }
        if (!self.directed && self.adj.hasKey(v)) {
            new_v = list()
            for (e in self.adj[v]) {
                if (e[0] != u) new_v.push(e)
            }
            self.adj[v] = new_v
        }
        if (removed) self._ec -= 1
        return self
    }

    clear() = {
        self.adj = dict()
        self._ec = 0
        return self
    }

    // ── Queries ──
    vertices() -> list           = return self.adj.keys().toList()
    edgeCount() -> int           = return self._ec
    hasVertex(v: any) -> bool    = return self.adj.hasKey(v)

    hasEdge(u: any, v: any) -> bool = {
        if (!self.adj.hasKey(u)) return false
        for (e in self.adj[u]) { if (e[0] == v) return true }
        return false
    }
    
    __call__(u: any, v: any) -> bool = return self.hasEdge(u, v)

    getWeight(u: any, v: any) -> any = {
        if (self.adj.hasKey(u)) {
            for (e in self.adj[u]) { if (e[0] == v) return e[1] }
        }
        return none
    }

    neighbors(v: any) -> list = {
        if (!self.adj.hasKey(v)) return list()
        return self.adj[v].map((e) => e[0])
    }

    edges() -> list = {
        res = list()
        for (k in self.adj.keys()) {
            for (e in self.adj[k]) res.push(list(k, e[0], e[1]))
        }
        return res
    }

    outDegree(v: any) -> int = {
        return self.adj.hasKey(v) ? self.adj[v].len() : 0
    }

    inDegree(v: any) -> int = {
        c = 0
        for (k in self.adj.keys()) {
            for (e in self.adj[k]) { if (e[0] == v) c += 1 }
        }
        return c
    }

    // ── Traversals ──
    bfs(start: any) -> list = {
        visited = set(start); q = list(start); res = list()
        while (q.len() > 0) {
            curr = q.shift(); res.push(curr)
            if (self.adj.hasKey(curr)) {
                for (e in self.adj[curr]) {
                    if (!(e[0] in visited)) { visited.add(e[0]); q.push(e[0]) }
                }
            }
        }
        return res
    }

    dfs(start: any) -> list = {
        visited = set(); res = list()
        _go(v: any) = {
            if (v in visited) return none
            visited.add(v); res.push(v)
            if (self.adj.hasKey(v)) {
                for (e in self.adj[v]) _go(e[0])
            }
        }
        _go(start)
        return res
    }

    // ── Path Algorithms ──
    findPath(start: any, end: any) -> list = {
        if (start == end) return list(start)
        
        visited = set(start); q = list(list(start))
        while (q.len() > 0) {
            path = q.shift(); curr = path.last()
            if (self.adj.hasKey(curr)) {
                for (e in self.adj[curr]) {
                    nbr = e[0]
                    np = list(); for (p in path) np.push(p); np.push(nbr)
                    if (nbr == end) return np
                    if (!(nbr in visited)) { visited.add(nbr); q.push(np) }
                }
            }
        }
        return list()
    }

    dijkstra(start: any) -> dict = {
        vs = self.adj.keys().toList()
        dist = dict(); prev = dict()
        for (v in vs) dist[v] = none
        dist[start] = 0; visited = set()
        
        while (visited.len() < vs.len()) {
            minV = none; minD = none
            for (v in vs) {
                if (!(v in visited) && !dist[v].isnone()) {
                    if (minD.isnone() || dist[v] < minD) { minD = dist[v]; minV = v }
                }
            }
            if (minV.isnone()) break
            visited.add(minV)
            
            if (self.adj.hasKey(minV)) {
                for (e in self.adj[minV]) {
                    nbr = e[0]; w = e[1]
                    alt = dist[minV] + w
                    if (dist[nbr].isnone() || alt < dist[nbr]) {
                        dist[nbr] = alt; prev[nbr] = minV
                    }
                }
            }
        }
        return {dist: dist, prev: prev}
    }

    shortestPath(start: any, end: any) -> dict = {
        r = self.dijkstra(start)
        if (r.dist[end].isnone()) return {path: list(), dist: none}
        
        path = list(); curr = end
        while (!curr.isnone()) {
            path.push(curr)
            curr = r.prev.hasKey(curr) ? r.prev[curr] : none
        }
        return {path: path.reverse(), dist: r.dist[end]}
    }

    // ── Topology & Properties ──
    hasCycle() -> bool = {
        vs = self.adj.keys().toList()
        found = list(false)

        if (self.directed) {
            color = dict(); for (v in vs) color[v] = 0
            _visit(v: any) = {
                if (found[0]) return none
                color[v] = 1
                if (self.adj.hasKey(v)) {
                    for (e in self.adj[v]) {
                        if (color[e[0]] == 1) { found[0] = true; return none }
                        if (color[e[0]] == 0) _visit(e[0])
                    }
                }
                color[v] = 2
            }
            for (v in vs) { if (color[v] == 0) _visit(v) }
        } else {
            visited = set()
            _visit(v: any, parent: any) = {
                if (found[0]) return none
                visited.add(v)
                if (self.adj.hasKey(v)) {
                    for (e in self.adj[v]) {
                        if (e[0] == parent) continue
                        if (e[0] in visited) { found[0] = true; return none }
                        _visit(e[0], v)
                    }
                }
            }
            for (v in vs) { if (!(v in visited)) _visit(v, none) }
        }
        return found[0]
    }

    topSort() -> list = {
        if (!self.directed) throw "Graph Error: topSort() requires a directed graph."
        
        vs = self.adj.keys().toList()
        inDeg = dict(); for (v in vs) inDeg[v] = 0
        for (v in vs) {
            if (self.adj.hasKey(v)) {
                for (e in self.adj[v]) inDeg[e[0]] = inDeg[e[0]] + 1
            }
        }
        
        q = list()
        for (v in vs) { if (inDeg[v] == 0) q.push(v) }
        res = list()
        
        while (q.len() > 0) {
            v = q.shift(); res.push(v)
            if (self.adj.hasKey(v)) {
                for (e in self.adj[v]) {
                    inDeg[e[0]] = inDeg[e[0]] - 1
                    if (inDeg[e[0]] == 0) q.push(e[0])
                }
            }
        }
        if (res.len() != vs.len()) throw "Graph Error: Cycle detected, topological sort impossible."
        return res
    }

    components() -> list = {
        if (self.directed) throw "Graph Error: components() requires an undirected graph."
        
        visited = set(); comps = list()
        for (v in self.adj.keys().toList()) {
            if (v in visited) continue
            comp = list(); q = list(v); visited.add(v)
            while (q.len() > 0) {
                curr = q.shift(); comp.push(curr)
                if (self.adj.hasKey(curr)) {
                    for (e in self.adj[curr]) {
                        if (!(e[0] in visited)) { visited.add(e[0]); q.push(e[0]) }
                    }
                }
            }
            comps.push(comp)
        }
        return comps
    }

    __contains__(v: any) -> bool = return self.hasVertex(v)
    __len__() -> int             = return self.adj.keys().len()
    __str__() -> string          = return f"<Graph({self.directed ? 'directed' : 'undirected'}) V={len(self)} E={self._ec}>"
}

// ┌────────────────────────────────────────────────────────┐
// │ 5. STANDALONE TRUTH TABLE                              │
// └────────────────────────────────────────────────────────┘

truthTable(n: int, fn: func) -> list = {
    total = 2 ^ n; res_list = list()
    for (i in range(total)) {
        vars = zeros(1, n)
        for (j in range(n)) { vars[j] = int(i / (2^(n - 1 - j))) % 2 }
        res_list.push({inputs: vars, output: vars.apply(fn) ? 1 : 0})
    }
    return res_list
}

printTruthTable(n: int, fn: func) = {
    total = 2 ^ n
    print(f"\nTruth Table ({n} variables):")
    print("-" * (n * 7 + 10))
    header = ""
    for (i in range(n)) { header += f"V{i}     " }
    header += "|   Out"
    print(header); print("-" * (n * 7 + 10))
    for (i in range(total)) {
        vars = zeros(1, n)
        for (j in range(n)) { vars[j] = int(i / (2^(n - 1 - j))) % 2 }
        rowStr = ""
        for (v in vars) { rowStr += f" {v}     " }
        rowStr += f"|    {vars.apply(fn) ? 1 : 0}"
        print(rowStr)
    }
    print("-" * (n * 7 + 10))
}

// ┌────────────────────────────────────────────────────────┐
// │ 6. HELP TEXT REGISTRATION                              │
// └────────────────────────────────────────────────────────┘

if (isfunction(__register_help)) {
    __register_help("discrete", r"DOC(
═══ Discrete Mathematics Standard Library ═══

  Requires: import discrete

  A pure JC2 implementation covering Combinatorics, Graph Theory, 
  Binary Relations, and Boolean Logic.

  Combinatorics
  ──────────────────────
    arr.permutations()         Returns all permutations of elements.
    arr.combinations(k)        Returns all k-subsets.

  Propositional Logic (class Prop)
  ──────────────────────
    Var("p")                   Create an atomic proposition variable
    A & B  /  A | B  /  -A     AND, OR, NOT (operator overloading)
    A.implies(B) / A.iff(B)    Material implication and Biconditional

    p.eval(env) / p(env)       Evaluate with a variable binding Dict (Callable)
    p.vars()                   Collect all variables (Set)
    p.table()                  Return full truth table data
    p.printTable()             Print formatted truth table
    p.isTautology()            True for all assignments
    p.isContradiction()        False for all assignments
    p.isSatisfiable()          True for at least one assignment
    p.equiv(other)             Logically equivalent to other Prop

  Standalone Truth Tables
  ──────────────────────
    truthTable(n, fn)          Returns truth table data for an n-ary function
    printTruthTable(n, fn)     Prints a formatted truth table for the function

  Binary Relations (class Relation)
  ──────────────────────
    r = Relation(set(1,2))     Create relation over base Set S
    r.addPair(a, b)            Add relation (checks bounds in S)
    r.removePair(a, b)         Remove relation securely
    r.hasPair(a, b) / r(a, b)  Presence query (Callable)
    r.clearPairs()             Delete all relations

    r.isReflexive()            r.isSymmetric()      r.isTransitive()
    r.isAntiSymmetric()        r.isIrreflexive()
    r.isEquivalence()          r.isPartialOrder()   r.isTotalOrder()
    
    r.inverse()                R^{-1} = {(b,a)|(a,b) in R}
    r.compose(other)           R ; S composition
    r.reflexiveClosure()       r.symmetricClosure() r.transitiveClosure()
    r.equivalenceClasses()     Partition into sets of equivalence classes

  Graph Theory (class Graph)
  ──────────────────────
    g = Graph(directed: bool)  Create Graph (True by default)
    g.addVertex(v)             Add vertex
    g.removeVertex(v)          Remove vertex & prune related edges
    g.addEdge(u, v, w=1)       Add edge (creates missing vertices)
    g.removeEdge(u, v)         Remove edge
    g.clear()                  Clear all vertices and edges
    
    g.vertices()               Return all vertices (List)
    g.edges()                  Return all edges (List)
    g.neighbors(v)             Return all adjacent vertices (List)
    g.hasVertex(v)             Vertex presence check
    g.hasEdge(u, v) / g(u, v)  Edge presence check (Callable)
    g.getWeight(u, v)          Edge weight retrieval
    g.inDegree(v)              g.outDegree(v)
    
    g.bfs(start)               g.dfs(start)
    g.findPath(start, end)     Unweighted shortest path
    g.dijkstra(start)          Weighted shortest paths (returns dict)
    g.shortestPath(start, end) Weighted path + minimum distance
    
    g.hasCycle()               Cycle detection
    g.topSort()                Topological sort (DAG only)
    g.components()             Connected components (undirected only)
)DOC")
}
