{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "JC2",
    "scopeName": "source.jc2",
    "patterns": [
        { "include": "#comments" },
        { "include": "#fstrings" },
        { "include": "#rstrings" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#class-def" },
        { "include": "#function-def" },
        { "include": "#function-call" },
        { "include": "#constants" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.jc2",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.jc2",
                    "begin": "\"",
                    "end": "\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.jc2" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.jc2" } },
                    "patterns": [
                        { "name": "constant.character.escape.jc2", "match": "\\\\[nrt\\\\\"0]" }
                    ]
                }
            ]
        },
        "fstrings": {
            "patterns": [
                {
                    "name": "string.interpolated.jc2",
                    "begin": "f\"",
                    "end": "\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.jc2" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.jc2" } },
                    "patterns": [
                        { "name": "constant.character.escape.jc2", "match": "\\\\[nrt\\\\\"0]" },
                        {
                            "name": "meta.interpolation.jc2",
                            "begin": "\\{",
                            "end": "\\}",
                            "contentName": "source.jc2.embedded",
                            "patterns": [ { "include": "source.jc2" } ]
                        }
                    ]
                }
            ]
        },
        "rstrings": {
            "patterns": [
                {
                    "comment": "Custom Delimiter Raw String: r\"TAG(content)TAG\"",
                    "name": "string.raw.delimited.jc2",
                    "begin": "r\"([a-zA-Z0-9_]*)\\(",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.jc2" } },
                    "end": "\\)\\1\"",
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.jc2" } }
                },
                {
                    "comment": "Simple Raw String: r\"content\"",
                    "name": "string.raw.simple.jc2",
                    "begin": "r\"",
                    "end": "\"",
                    "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.jc2" } },
                    "endCaptures": { "0": { "name": "punctuation.definition.string.end.jc2" } }
                }
            ]
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.imaginary.jc2", "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?[iI]\\b" },
                { "name": "constant.numeric.float.jc2", "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b" },
                { "name": "constant.numeric.scientific.jc2", "match": "\\b\\d+[eE][+-]?\\d+\\b" },
                { "name": "constant.numeric.integer.jc2", "match": "\\b\\d+[\\d_]*\\b" }
            ]
        },
        "keywords": {
            "patterns": [
                { "name": "keyword.control.jc2", "match": "\\b(if|else|while|for|in|break|continue|return|switch|case|default|throw|try|catch)\\b" },
                { "name": "keyword.declaration.jc2", "match": "\\b(class|extends|const|state|delete|ref|import)\\b" }
            ]
        },
        "class-def": {
            "patterns": [
                {
                    "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
                    "captures": {
                        "1": { "name": "keyword.declaration.class.jc2" },
                        "2": { "name": "entity.name.type.class.jc2" },
                        "3": { "name": "keyword.declaration.extends.jc2" },
                        "4": { "name": "entity.other.inherited-class.jc2" }
                    }
                }
            ]
        },
        "function-def": {
            "patterns": [
                { "match": "\\b(__[A-Za-z_][A-Za-z0-9_]*__)\\s*(?=\\()", "captures": { "1": { "name": "support.function.magic.jc2" } } },
                { "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\([^)]*\\)\\s*=)", "captures": { "1": { "name": "entity.name.function.definition.jc2" } } }
            ]
        },
        "function-call": {
            "patterns": [ { "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()", "captures": { "1": { "name": "entity.name.function.call.jc2" } } } ]
        },
        "constants": {
            "patterns": [
                { "name": "constant.language.jc2", "match": "\\b(true|false|none|PI|E|ANS)\\b" },
                { "name": "variable.language.jc2", "match": "\\b(self|super|_)\\b" }
            ]
        },
        "operators": {
            "patterns": [
                { "name": "keyword.operator.pipe.jc2", "match": "\\|>" },
                { "name": "keyword.operator.arrow.jc2", "match": "=>" },
                { "name": "keyword.operator.spread.jc2", "match": "\\.\\.\\." },
                { "name": "keyword.operator.comparison.jc2", "match": "==|!=|<=|>=|<|>" },
                { "name": "keyword.operator.logical.jc2", "match": "&&|\\|\\||!" },
                { "name": "keyword.operator.assignment.jc2", "match": "\\+=|-=|\\*=|/=|%=|\\^=|=" },
                { "name": "keyword.operator.arithmetic.jc2", "match": "\\+|-|\\*|/|%|\\^|\\\\|~" },
                { "name": "keyword.operator.ternary.jc2", "match": "\\?|:" }
            ]
        },
        "punctuation": {
            "patterns": [
                { "name": "punctuation.bracket.round.jc2", "match": "[()]" },
                { "name": "punctuation.bracket.square.jc2", "match": "[\\[\\]]" },
                { "name": "punctuation.bracket.curly.jc2", "match": "[{}]" },
                { "name": "punctuation.separator.jc2", "match": "[,;]" },
                { "name": "punctuation.accessor.jc2", "match": "\\." }
            ]
        },
        "identifiers": {
            "patterns": [ { "name": "variable.other.jc2", "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b" } ]
        }
    }
}
